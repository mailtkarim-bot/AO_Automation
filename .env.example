# ===== Application =====
APP_ENV=dev
APP_NAME=batiao
SECRET_KEY=change-me-in-production-please-32-chars-min
LOG_LEVEL=INFO

# ===== Multi-tenant =====
# En dev on travaille avec un tenant unique par défaut
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ===== PostgreSQL + pgvector =====
POSTGRES_USER=batiao
POSTGRES_PASSWORD=batiao
POSTGRES_DB=batiao
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://batiao:batiao@db:5432/batiao

# ===== MinIO (stockage fichiers S3-compatible) =====
MINIO_ROOT_USER=batiao
MINIO_ROOT_PASSWORD=batiao-super-secret
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=batiao-docs
MINIO_USE_SSL=false

# ===== Redis (files Celery + cache) =====
REDIS_URL=redis://redis:6379/0

# ===== Mistral IA (souverain FR) =====
# Option A : API La Plateforme (hébergée en France)
MISTRAL_API_KEY=
MISTRAL_MODEL_LARGE=mistral-large-latest
MISTRAL_MODEL_MEDIUM=mistral-medium-latest
MISTRAL_MODEL_SMALL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
# Option B : local via vLLM/Ollama (100% on-prem, pas de clé requise)
LLM_BACKEND=mistral_api   # mistral_api | local
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=mistral-nemo
